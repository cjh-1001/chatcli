include README.md
include config.example.yaml
include requirements.txt
include requirements-reverse.txt
include pyproject.toml

# Skills data files
recursive-include chatcli/skills *.md
recursive-include chatcli/skills *.py
recursive-include chatcli/skills *.yaml
recursive-include chatcli/skills *.yml
recursive-include chatcli/skills *.json

# Template data files
recursive-include chatcli/templates *.json
recursive-include chatcli/templates *.html

# IDA helper scripts
recursive-include chatcli/ida_scripts *.py
recursive-include chatcli/ida_scripts *.md

# Exclude local state
prune .chatcli
prune .claude
prune __pycache__
prune target
