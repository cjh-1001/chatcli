include README.md
include config.example.yaml
include requirements.txt
include requirements-reverse.txt
include pyproject.toml

# Skills data files
recursive-include chatcli/skills *.md
recursive-include chatcli/skills *.py

# Template data files
recursive-include chatcli/templates *.json

# IDA helper scripts
recursive-include chatcli/ida_scripts *.py
recursive-include chatcli/ida_scripts *.md

# Exclude local state
prune .chatcli
prune .claude
prune __pycache__
prune target
